// Mietwerk – Prisma schema (Phase 0 draft)
// Conventions enforced here:
//  - Money is stored as Int in Cent (suffix `Cents`), never as Float.
//  - All timestamps are stored in UTC (rendered in Europe/Berlin in the UI).
//  - Every tenant-owned entity carries `organizationId` for strict multi-tenancy.
//  - Personal / personenbezogene entities use Soft-Delete via `deletedAt`.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// AUTH (NextAuth / Auth.js – shapes required by @auth/prisma-adapter)
// =====================================================================

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft-Delete (personenbezogen)

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  auditLogs   AuditLog[]
}

// =====================================================================
// TENANCY: Organization (Mandant), Membership, Invitation
// =====================================================================

enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT_READONLY
}

enum PlanTier {
  FREE // 1 Einheit
  STARTER // bis 5
  PRO // bis 20
  BUSINESS // bis 50
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

/// The tenant boundary. Every domain row belongs to exactly one Organization.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription / Billing (Stripe – finalisiert in Phase 8)
  planTier             PlanTier           @default(FREE)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?

  memberships             Membership[]
  invitations             Invitation[]
  properties              Property[]
  tenants                 Tenant[]
  leases                  Lease[]
  rentPayments            RentPayment[]
  transactions            Transaction[]
  operatingCostStatements OperatingCostStatement[]
  depreciationSchedules   DepreciationSchedule[]
  maintenanceTickets      MaintenanceTicket[]
  contractors             Contractor[]
  dunnings                Dunning[]
  payments                Payment[]
  paymentAllocations      PaymentAllocation[]
  bankImports             BankImport[]
  bankTransactions        BankTransaction[]
  dunningPolicy           DunningPolicy?
  documents               Document[]
  auditLogs               AuditLog[]
  units                   Unit[]
  leaseOccupancies        LeaseOccupancy[]
  statementItemShares     OperatingCostStatementItemShare[]
  statementConsumptions   OperatingCostConsumption[]
}

/// Join between User and Organization, carrying the role within that org.
model Membership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole @default(OWNER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

/// Invitation flow for adding teammates to an organization.
model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           UserRole         @default(MANAGER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String?
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
}

// =====================================================================
// PROPERTIES & UNITS
// =====================================================================

enum PropertyType {
  MEHRFAMILIENHAUS
  EINFAMILIENHAUS
  EIGENTUMSWOHNUNG
  GEWERBE
  GEMISCHT
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           PropertyType @default(MEHRFAMILIENHAUS)

  // Adresse
  street     String
  houseNo    String
  postalCode String
  city       String
  country    String @default("DE")

  buildYear Int?

  // AfA-relevante Stammdaten (Geldbeträge in Cent)
  completionDate        DateTime? // Fertigstellung — bestimmt den linearen AfA-Satz (§ 7 Abs. 4 EStG)
  constructionStartDate DateTime? // angezeigter Baubeginn — Eignung degressive AfA (§ 7 Abs. 5a EStG)
  purchaseDate          DateTime?
  purchasePriceCents    Int? // Gesamtkaufpreis
  landValueCents        Int? // Grundstücksanteil (nicht abschreibbar)
  buildingValueCents    Int? // Gebäudeanteil (Bemessungsgrundlage AfA)
  acquisitionCostCents  Int? // anteilige Anschaffungsnebenkosten auf das Gebäude (erhöhen die AfA-Basis)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units                   Unit[]
  transactions            Transaction[]
  depreciationSchedules   DepreciationSchedule[]
  maintenanceTickets      MaintenanceTicket[]
  operatingCostStatements OperatingCostStatement[]
  documents               Document[]

  @@index([organizationId])
}

model Unit {
  id             String  @id @default(cuid())
  organizationId String
  propertyId     String
  label          String // z.B. "Wohnung 2 OG links"
  floor          String?
  rooms          Float?
  areaSqm        Float? // Wohnfläche in m²

  // Aktuelle Soll-Konditionen (Geldbeträge in Cent)
  baseRentCents             Int? // Kaltmiete
  operatingCostAdvanceCents Int? // Nebenkostenvorauszahlung

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]
  consumptions OperatingCostConsumption[]
  documents    Document[]

  @@index([organizationId])
  @@index([propertyId])
}

// =====================================================================
// TENANTS & LEASES
// =====================================================================

model Tenant {
  id             String  @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  email          String?
  phone          String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft-Delete (personenbezogen)

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaseTenants LeaseTenant[]
  documents    Document[]

  @@index([organizationId])
}

enum LeaseType {
  STANDARD
  STAFFELMIETE
  INDEXMIETE
}

model Lease {
  id             String    @id @default(cuid())
  organizationId String
  unitId         String
  type           LeaseType @default(STANDARD)
  startDate      DateTime
  endDate        DateTime? // null = unbefristet

  // Konditionen (Geldbeträge in Cent)
  baseRentCents             Int // Kaltmiete
  operatingCostAdvanceCents Int @default(0) // Nebenkostenvorauszahlung
  depositCents              Int @default(0) // Kaution

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit         Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leaseTenants LeaseTenant[]
  rentPayments RentPayment[]
  payments     Payment[]
  occupancies  LeaseOccupancy[]
  documents    Document[]

  @@index([organizationId])
  @@index([unitId])
}

/// Effektiv-datierte Personenzahl je Mietverhältnis (für den Personen-Umlage-
/// schlüssel, § 556a BGB i.V.m. Vereinbarung). Intervalle [validFrom, validTo)
/// erlauben tagesgenaue Personen-Tage über einen Abrechnungszeitraum; offenes
/// Ende (`validTo = null`) gilt bis auf Weiteres.
model LeaseOccupancy {
  id             String    @id @default(cuid())
  organizationId String
  leaseId        String
  personCount    Int // Anzahl Personen im Haushalt (>= 0)
  validFrom      DateTime // UTC-Kalendertag, ab dem der Wert gilt (inklusive)
  validTo        DateTime? // UTC-Kalendertag, bis zu dem der Wert gilt (exklusive); null = offen

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leaseId])
}

/// m:n between Lease and Tenant (mehrere Mieter pro Mietverhältnis).
model LeaseTenant {
  leaseId  String
  tenantId String
  lease    Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([leaseId, tenantId])
}

// =====================================================================
// RENT PAYMENTS & DUNNING
// =====================================================================

enum RentPaymentStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

model RentPayment {
  id             String   @id @default(cuid())
  organizationId String
  leaseId        String
  dueDate        DateTime // Sollstellungsdatum
  periodYear     Int
  periodMonth    Int // 1-12

  // Geldbeträge in Cent
  targetCents Int // Sollstellung
  paidCents   Int               @default(0) // Ist
  paidAt      DateTime?
  status      RentPaymentStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lease        Lease               @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  dunnings     Dunning[]
  allocations  PaymentAllocation[]

  @@unique([leaseId, periodYear, periodMonth])
  @@index([organizationId])
}

enum DunningLevel {
  REMINDER // Zahlungserinnerung
  FIRST // 1. Mahnung
  SECOND // 2. Mahnung
  FINAL // letzte Mahnung / Inkasso-Androhung
}

model Dunning {
  id             String       @id @default(cuid())
  organizationId String
  rentPaymentId  String
  level          DunningLevel
  sentAt         DateTime?
  feeCents       Int          @default(0) // Mahngebühr — nur als tatsächlicher Verzugsschaden (§ 280/286 BGB)
  interestCents  Int          @default(0) // Verzugszinsen (§ 288 Abs. 1 BGB); 0 wenn deaktiviert
  channel        String       @default("EMAIL") // Ausgabekanal (Phase 2: E-Mail/Text an Mailpit, kein PDF)
  recipient      String? // Empfänger-Adresse des Schreibens (Mieter-E-Mail)
  body           String? // generierter Schreiben-Text
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rentPayment  RentPayment  @relation(fields: [rentPaymentId], references: [id], onDelete: Cascade)

  // Jede Mahnstufe je Forderung nur einmal -> macht den Mahnlauf idempotent & monoton.
  @@unique([rentPaymentId, level])
  @@index([organizationId])
  @@index([rentPaymentId])
}

// =====================================================================
// PAYMENTS (Ist-Eingänge) & BANK IMPORT (Kontoumsatz)
// =====================================================================

enum PaymentMethod {
  MANUAL // manuell erfasst
  BANK_IMPORT // aus Kontoumsatz-Import verbucht
}

/// A received payment (Ist-Eingang). The amount is allocated to one or more
/// rent receivables via PaymentAllocation; any unallocated remainder is Guthaben.
model Payment {
  id                String        @id @default(cuid())
  organizationId    String
  leaseId           String? // optional: noch keinem Mietverhältnis zugeordnet (unklarer Eingang)
  amountCents       Int // Eingang in Cent (immer positiv)
  valueDate         DateTime // Wertstellung / Zahlungsdatum (UTC gespeichert)
  method            PaymentMethod @default(MANUAL)
  counterparty      String? // Name des Zahlers
  reference         String? // Verwendungszweck / Buchungstext
  note              String?
  bankTransactionId String?       @unique // Herkunft aus Import (1:1), wenn aus Kontoumsatz

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lease           Lease?              @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  bankTransaction BankTransaction?    @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)
  allocations     PaymentAllocation[]

  @@index([organizationId])
  @@index([leaseId])
}

/// Allocation of (part of) a payment to a single rent receivable. The sum of a
/// payment's allocations is always <= payment.amountCents.
model PaymentAllocation {
  id             String   @id @default(cuid())
  organizationId String
  paymentId      String
  rentPaymentId  String
  amountCents    Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  rentPayment  RentPayment  @relation(fields: [rentPaymentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([paymentId])
  @@index([rentPaymentId])
}

enum BankImportFormat {
  CSV
  CAMT053
}

/// A batch of imported bank transactions (one uploaded file).
model BankImport {
  id             String           @id @default(cuid())
  organizationId String
  fileName       String
  format         BankImportFormat @default(CSV)
  rowCount       Int              @default(0)
  importedById   String?
  createdAt      DateTime         @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@index([organizationId])
}

enum BankTransactionStatus {
  PENDING // importiert, noch nicht verbucht
  BOOKED // als Payment verbucht
  IGNORED // bewusst ignoriert
}

/// A single imported bank line. `dedupeHash` makes re-importing the same file
/// idempotent (no double-booking). Once booked it links 1:1 to a Payment.
model BankTransaction {
  id               String                @id @default(cuid())
  organizationId   String
  importId         String
  bookingDate      DateTime
  valueDate        DateTime?
  amountCents      Int // Betrag (positiv = Gutschrift/Eingang)
  counterparty     String? // Name des Zahlers
  reference        String? // Verwendungszweck
  dedupeHash       String // Hash über (Datum, Betrag, Zweck, Name) -> Idempotenz
  status           BankTransactionStatus @default(PENDING)
  suggestedLeaseId String? // Zuordnungsvorschlag (Betrag/Zweck/Name)
  createdAt        DateTime              @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  import       BankImport   @relation(fields: [importId], references: [id], onDelete: Cascade)
  payment      Payment?

  @@unique([organizationId, dedupeHash])
  @@index([organizationId])
  @@index([importId])
}

// =====================================================================
// DUNNING POLICY (konfigurierbares Mahnwesen)
// =====================================================================

/// Per-organization dunning configuration. Thresholds and rates are
/// configurable (not hard-coded) so they can be adjusted after legal review.
model DunningPolicy {
  id             String @id @default(cuid())
  organizationId String @unique
  toleranceDays  Int    @default(3) // Karenz nach Fälligkeit, bevor "überfällig" gilt

  // Verzugszinsen: für Verbraucher 5 Prozentpunkte über dem Basiszinssatz
  // (§ 288 Abs. 1 BGB). Der Basiszinssatz ist variabel (§ 247 BGB) und daher
  // als Feld pflegbar. Standardmäßig deaktiviert (rechtlich heikel).
  interestEnabled       Boolean @default(false)
  baseRatePercent       Float   @default(0) // Basiszinssatz (§ 247 BGB) — vom Nutzer zu pflegen
  interestMarginPercent Float   @default(5) // Aufschlag in Prozentpunkten (§ 288 Abs. 1 BGB)

  // Mahngebühren: nur als tatsächlicher Verzugsschaden ansetzbar, keine freie
  // Pauschale (§ 280/286 BGB). Standardmäßig deaktiviert.
  feesEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  levels       DunningPolicyLevel[]
}

/// A single configurable dunning level (threshold + optional fee).
model DunningPolicyLevel {
  id             String       @id @default(cuid())
  policyId       String
  level          DunningLevel
  minDaysOverdue Int // Tage über Fälligkeit, ab denen diese Stufe greift (inkl. Toleranz)
  feeCents       Int          @default(0) // Mahngebühr dieser Stufe (nur realer Verzugsschaden)

  policy DunningPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, level])
}

// =====================================================================
// COSTS / ACCOUNTING (Belege & Transaktionen)
// =====================================================================

enum TransactionCategory {
  GRUNDSTEUER
  VERSICHERUNG
  HEIZUNG
  WASSER
  ABWASSER
  MUELL
  HAUSREINIGUNG
  HAUSMEISTER
  STROM_ALLGEMEIN
  AUFZUG
  GARTENPFLEGE
  SCHORNSTEINFEGER
  INSTANDHALTUNG
  VERWALTUNG
  FINANZIERUNGSZINSEN
  SONSTIGE
}

/// Steuerliche Behandlung einer Ausgabe (siehe ADR 0009).
enum ExpenseType {
  SOFORTABZUG // Erhaltungsaufwand, sofort als Werbungskosten abziehbar
  VERTEILUNG_82B // größerer Erhaltungsaufwand, auf 2–5 Jahre verteilt (§ 82b EStDV)
  HERSTELLUNG_AKTIVIEREN // Herstellungskosten → über AfA (kein Sofortabzug)
  ANSCHAFFUNGSNAH // anschaffungsnahe HK (§ 6 Abs. 1 Nr. 1a) → wie Herstellungskosten
  ANSCHAFFUNGSNEBENKOSTEN // erhöhen die AfA-Bemessungsgrundlage (Gebäudeanteil)
  NICHT_ABZIEHBAR // nicht abziehbar / privat veranlasst
}

model Transaction {
  id             String              @id @default(cuid())
  organizationId String
  propertyId     String?
  unitId         String?
  bookingDate    DateTime // Beleg-/Rechnungsdatum
  paidDate       DateTime? // Zahlungsabfluss — maßgeblich für die Kassenbasis (§ 11 EStG)
  category       TransactionCategory @default(SONSTIGE)
  description    String?

  amountCents    Int // gebuchter Betrag in Cent (positiv = Ausgabe; brutto = Werbungskosten)
  netAmountCents Int? // ohne USt — Bezugsgröße für die 15 %-Prüfung (§ 6 Abs. 1 Nr. 1a)
  isAllocatable  Boolean        @default(false) // umlagefähig (BetrKV)
  allocationKey  AllocationKey? // Umlageschlüssel-Hinweis (Abrechnung erst Phase 4)
  isAfaRelevant  Boolean        @default(false) // AfA-relevant (Anschaffung/Herstellung)
  isLaborCost35a Boolean        @default(false) // § 35a EStG Arbeitskostenanteil (bei Vermietung i.d.R. Werbungskosten)

  // Steuerliche Behandlung + optionale § 82b-Verteilung (ADR 0009)
  expenseType           ExpenseType @default(SOFORTABZUG)
  distributionYears     Int? // § 82b EStDV: 2–5 Jahre (nur bei VERTEILUNG_82B)
  distributionStartYear Int? // erstes Jahr der Verteilung (Default: Jahr des Abflusses)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit         Unit?        @relation(fields: [unitId], references: [id], onDelete: SetNull)
  documents    Document[]

  @@index([organizationId])
  @@index([propertyId])
}

// =====================================================================
// OPERATING COST STATEMENT (Betriebskostenabrechnung)
// =====================================================================

enum AllocationKey {
  WOHNFLAECHE // nach Quadratmeter
  PERSONEN // nach Personenzahl
  EINHEITEN // nach Anzahl Einheiten
  VERBRAUCH // nach gemessenem Verbrauch
  MITEIGENTUMSANTEIL // nach MEA
}

enum StatementStatus {
  DRAFT
  FINALIZED
  SENT
}

/// Anrechnungsbasis der Nebenkostenvorauszahlungen in der Abrechnung.
enum AdvanceBasis {
  SOLL // vereinbarte Vorauszahlungen (zeitanteilig)
  IST // tatsächlich geleistete Vorauszahlungen (NK-Anteil der Ist-Zahlungen)
}

/// Eine Betriebskostenabrechnung für genau EIN Objekt und einen
/// Abrechnungszeitraum von höchstens 12 Monaten (§ 556 Abs. 3 BGB).
model OperatingCostStatement {
  id             String          @id @default(cuid())
  organizationId String
  propertyId     String
  title          String? // z.B. "Betriebskostenabrechnung 2025"
  periodYear     Int
  periodStart    DateTime // UTC, erster Tag des Zeitraums (inklusive)
  periodEnd      DateTime // UTC, letzter Tag des Zeitraums (inklusive)
  status         StatementStatus @default(DRAFT)

  // Anrechnung der Vorauszahlungen (Auftraggeber-Entscheidung: IST).
  advanceBasis AdvanceBasis @default(IST)

  // Heizkostenverordnung: Default-Verbrauchsanteil in Basispunkten (5000 = 50 %).
  // Gesetzlicher Korridor 50–70 % (§ 7 Abs. 1 / § 8 Abs. 1 HeizkostenV); je
  // Position überschreibbar. ⚠️ konfigurierbar, vor Freigabe zu prüfen.
  heatingConsumptionShareBp Int @default(5000)

  finalizedAt DateTime?
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property                          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lineItems    OperatingCostStatementItem[]
  results      OperatingCostStatementResult[]
  itemShares   OperatingCostStatementItemShare[]
  consumptions OperatingCostConsumption[]

  @@index([organizationId])
  @@index([propertyId])
}

/// Eine Kostenposition der Abrechnung mit ihrem Umlageschlüssel. Beträge werden
/// als Snapshot kopiert, damit eine finalisierte Abrechnung unveränderlich
/// bleibt, auch wenn sich Belege später ändern.
model OperatingCostStatementItem {
  id            String               @id @default(cuid())
  statementId   String
  label         String
  category      TransactionCategory? // Herkunfts-Kategorie (Gruppierung/Erläuterung)
  totalCents    Int // Gesamtkosten der Position (Snapshot)
  allocationKey AllocationKey
  note          String? // Erläuterung des Verteilerschlüssels (Formalanforderung BGH)

  // Heizkostenverordnung: bei Heizung/Warmwasser wird die Position in
  // Grundkosten (nach Fläche) und Verbrauchskosten (nach erfasstem Verbrauch)
  // gesplittet. consumptionShareBp überschreibt den Statement-Default.
  consumptionSplit   Boolean @default(false)
  consumptionShareBp Int? // Verbrauchsanteil in Basispunkten (null = Statement-Default)
  sortOrder          Int     @default(0)

  statement    OperatingCostStatement            @relation(fields: [statementId], references: [id], onDelete: Cascade)
  shares       OperatingCostStatementItemShare[]
  consumptions OperatingCostConsumption[]

  @@index([statementId])
}

/// Erfasster Verbrauchswert je Einheit für eine Position (Heizung/Warmwasser/
/// Wasser …). Manuell erfasst — keine Messdienstleister-Anbindung (out of scope).
/// Die Einheit (kWh, m³ …) ergibt sich aus der Position.
model OperatingCostConsumption {
  id             String @id @default(cuid())
  organizationId String
  statementId    String
  itemId         String
  unitId         String
  value          Float // erfasster Verbrauch in der Einheit der Position

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statement    OperatingCostStatement     @relation(fields: [statementId], references: [id], onDelete: Cascade)
  item         OperatingCostStatementItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unit         Unit                       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([itemId, unitId])
  @@index([organizationId])
  @@index([statementId])
}

/// Anteil EINER Position, der auf EINEN Mieter (leaseId) bzw. auf den Vermieter
/// (leaseId = null, z.B. Leerstand) entfällt. Die Summe der Shares je Position
/// ergibt exakt `totalCents` der Position (verlustfreie Verteilung).
model OperatingCostStatementItemShare {
  id             String  @id @default(cuid())
  organizationId String
  statementId    String
  itemId         String
  leaseId        String? // null = Vermieteranteil (Leerstand / nicht umlegbar)
  shareCents     Int
  basisLabel     String? // nachvollziehbare Bezugsgröße, z.B. "72 / 180 m²", "120 / 365 Tage"

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statement    OperatingCostStatement     @relation(fields: [statementId], references: [id], onDelete: Cascade)
  item         OperatingCostStatementItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([statementId])
  @@index([itemId])
}

/// Ergebnis je Mieter (Nachzahlung > 0 / Guthaben < 0).
model OperatingCostStatementResult {
  id          String @id @default(cuid())
  statementId String
  leaseId     String

  allocatedCents   Int // Summe der umgelegten Kostenanteile
  advanceSollCents Int @default(0) // vereinbarte Vorauszahlungen (zeitanteilig)
  advanceIstCents  Int @default(0) // tatsächlich geleistete NK-Vorauszahlungen
  advanceCents     Int // angerechnete Vorauszahlung gemäß advanceBasis
  balanceCents     Int // allocated - advance (positiv = Nachzahlung, negativ = Guthaben)

  daysActive Int @default(0) // aktive Tage des Mietverhältnisses im Zeitraum
  periodDays Int @default(0) // Gesamttage des Abrechnungszeitraums

  statement OperatingCostStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@unique([statementId, leaseId])
}

// =====================================================================
// TAX / AfA
// =====================================================================

enum DepreciationMethod {
  LINEAR
  DEGRESSIV
  RESTNUTZUNGSDAUER
}

model DepreciationSchedule {
  id              String             @id @default(cuid())
  organizationId  String
  propertyId      String
  method          DepreciationMethod @default(LINEAR)
  baseCents       Int // Bemessungsgrundlage (Gebäudeanteil + anteilige Nebenkosten)
  ratePercent     Float // jährlicher AfA-Satz in Prozent (linear/degressiv); bei RND aus usefulLifeYears
  startYear       Int
  startMonth      Int                @default(1) // 1–12, für monatsgenaue AfA im Anschaffungs-/Fertigstellungsjahr
  usefulLifeYears Int? // (Rest-)Nutzungsdauer in Jahren — v.a. bei RESTNUTZUNGSDAUER (§ 7 Abs. 4 S. 2)
  note            String? // z.B. Verweis auf Restnutzungsdauer-Gutachten (markiert, ADR 0009)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property                    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  entries      DepreciationScheduleEntry[]

  @@index([organizationId])
  @@index([propertyId])
}

model DepreciationScheduleEntry {
  id          String @id @default(cuid())
  scheduleId  String
  year        Int
  amountCents Int // AfA-Betrag dieses Jahres

  schedule DepreciationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, year])
}

// =====================================================================
// MAINTENANCE
// =====================================================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  DONE
  CANCELED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Contractor {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  trade          String? // Gewerk
  email          String?
  phone          String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  maintenanceTickets MaintenanceTicket[]

  @@index([organizationId])
}

model MaintenanceTicket {
  id                 String         @id @default(cuid())
  organizationId     String
  propertyId         String
  contractorId       String?
  title              String
  description        String?
  status             TicketStatus   @default(OPEN)
  priority           TicketPriority @default(MEDIUM)
  estimatedCostCents Int?
  actualCostCents    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contractor   Contractor?  @relation(fields: [contractorId], references: [id], onDelete: SetNull)
  documents    Document[]

  @@index([organizationId])
  @@index([propertyId])
}

// =====================================================================
// DOCUMENTS & AUDIT LOG
// =====================================================================

enum DocumentType {
  MIETVERTRAG
  SELBSTAUSKUNFT
  BELEG
  ABRECHNUNG
  MAHNUNG
  FOTO
  SONSTIGES
}

/// Polymorphic document attachment. Exactly one of the optional FKs is set.
model Document {
  id             String       @id @default(cuid())
  organizationId String
  type           DocumentType @default(SONSTIGES)
  fileName       String
  fileKey        String // Storage key (S3/Blob)
  mimeType       String?
  sizeBytes      Int?

  propertyId          String?
  unitId              String?
  tenantId            String?
  leaseId             String?
  transactionId       String?
  maintenanceTicketId String?

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property          Property?          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit              Unit?              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease             Lease?             @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  transaction       Transaction?       @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  maintenanceTicket MaintenanceTicket? @relation(fields: [maintenanceTicketId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// Audit trail for sensitive actions (DSGVO / Nachvollziehbarkeit).
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String // z.B. "tenant.delete", "statement.finalize"
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([entityType, entityId])
}
