# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# NextAuth / Auth.js
# Generate a secret with: npx auth secret
AUTH_SECRET=""

# OAuth: GitHub (https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email (magic link) provider – defaults target the local Mailpit container.
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1025"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Mietwerk <no-reply@mietwerk.local>"

# Object storage (documents & photos).
# STORAGE_DRIVER = "fs" (local filesystem, default/CI) | "s3" (MinIO/R2/Azure)
STORAGE_DRIVER="s3"
STORAGE_FS_DIR=".storage"
# MinIO defaults (matches docker-compose.yml). Console: http://localhost:9001
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="mietwerk"
S3_FORCE_PATH_STYLE="true"

# Anthropic API (KI-Features, Phase 6) – optional, app starts without it.
ANTHROPIC_API_KEY=""

# Prisma / PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5432/mietwerk"
